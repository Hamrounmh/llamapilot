<Window x:Class="LLamaCppLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LLamaCppLauncher.ViewModels"
        xmlns:loc="clr-namespace:LLamaCppLauncher.Helpers"
        Title="LLamaCpp Launcher" Height="750" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResizeWithGrip">

    <WindowChrome.WindowChrome>
        <WindowChrome 
            CaptionHeight="40"
            CornerRadius="0"
            GlassFrameThickness="0"
            ResizeBorderThickness="6"
            UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#B0B0B0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Normal"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="CaretBrush" Value="#E0E0E0"/>
            <Setter Property="SelectionBrush" Value="#007ACC"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#007ACC"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#505058"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}" 
                                CornerRadius="4" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1C97EA"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#005A9E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#3F3F46"/>
                                <Setter Property="Foreground" Value="#6D6D6D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SmallButton" TargetType="Button">
            <Setter Property="Background" Value="#3F3F46"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}" 
                                CornerRadius="3" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#505058"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2D2D30"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StartButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#2E7D32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}" 
                                CornerRadius="4" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#388E3C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1B5E20"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#2E4A2E"/>
                                <Setter Property="Foreground" Value="#6D6D6D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StopButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#C62828"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}" 
                                CornerRadius="4" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#D32F2F"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#B71C1C"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#4A2E2E"/>
                                <Setter Property="Foreground" Value="#6D6D6D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RestartButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#EF6C00"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}" 
                                CornerRadius="4" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F57C00"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E65100"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#4A3A2E"/>
                                <Setter Property="Foreground" Value="#6D6D6D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WindowControlButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#B0B0B0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3F3F46"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource WindowControlButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.3" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#007ACC"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="SubSectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#4EC9B0"/>
            <Setter Property="Margin" Value="0,4,0,4"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2D2D30" BorderBrush="#3F3F46" BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="MinimizeButton" Content="─" Style="{StaticResource WindowControlButton}" 
                            Click="MinimizeButton_Click" ToolTip="{loc:Loc title.minimize}"/>
                    <Button x:Name="MaximizeButton" Content="☐" Style="{StaticResource WindowControlButton}" 
                            Click="MaximizeButton_Click" ToolTip="{loc:Loc title.maximize}"/>
                    <Button x:Name="CloseBtn" Content="✕" Style="{StaticResource CloseButton}" 
                            Click="CloseButton_Click" ToolTip="{loc:Loc title.close}"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center"
                            WindowChrome.IsHitTestVisibleInChrome="True" Margin="0,0,8,0">
                    <Button Content="{Binding LanguageLabel}" Command="{Binding SwitchLanguageCommand}"
                            Style="{StaticResource SmallButton}" Width="36" Height="24" Padding="0"
                            FontSize="10" FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0"
                            WindowChrome.IsHitTestVisibleInChrome="False">
                    <TextBlock Text="🦙" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="LLamaCpp Launcher" FontSize="14" FontWeight="SemiBold" 
                               Foreground="#E0E0E0" VerticalAlignment="Center"/>
                    <TextBlock Text="  •  Open Source" FontSize="11" Foreground="#6D6D6D" 
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="8,6,8,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}">
                            <Run Text="⚙"/>
                            <Run Text="{loc:Loc config.title}"/>
                        </TextBlock>

                        <Label Content="{loc:Loc config.llama_dir}" Margin="0,0,0,1"/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding LlamaCppDirectory, UpdateSourceTrigger=PropertyChanged}" 
                                     IsReadOnly="True" VerticalContentAlignment="Center"/>
                            <Button Grid.Column="1" Content="📁" Command="{Binding BrowseLlamaDirCommand}" 
                                    Style="{StaticResource SmallButton}" Margin="4,0,0,0" Width="30"
                                    ToolTip="{loc:Loc config.browse}"/>
                        </Grid>

                        <Label Content="{loc:Loc config.models_dir}" Margin="0,0,0,1"/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding ModelsDirectory, UpdateSourceTrigger=PropertyChanged}" 
                                     IsReadOnly="True" VerticalContentAlignment="Center"/>
                            <Button Grid.Column="1" Content="📁" Command="{Binding BrowseModelsDirCommand}" 
                                    Style="{StaticResource SmallButton}" Margin="4,0,0,0" Width="30"
                                    ToolTip="{loc:Loc config.browse}"/>
                        </Grid>

                        <Label Content="{loc:Loc config.version}" Margin="0,0,0,1"/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0" ItemsSource="{Binding LlamaVersions}" 
                                      SelectedItem="{Binding SelectedVersion}"/>
                            <Button Grid.Column="1" Content="🔄" Command="{Binding RefreshVersionsCommand}" 
                                    Style="{StaticResource SmallButton}" Margin="4,0,0,0" Width="30" FontSize="11"
                                    ToolTip="{loc:Loc config.refresh}"/>
                        </Grid>

                        <Label Content="{loc:Loc config.model}" Margin="0,0,0,1"/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0" ItemsSource="{Binding Models}" 
                                      SelectedItem="{Binding SelectedModel}"
                                      DisplayMemberPath="DisplayName"/>
                            <Button Grid.Column="1" Content="🔄" Command="{Binding RefreshModelsCommand}" 
                                    Style="{StaticResource SmallButton}" Margin="4,0,0,0" Width="30" FontSize="11"
                                    ToolTip="{loc:Loc config.refresh}"/>
                            <Button Grid.Column="2" Content="⚙" Command="{Binding ManageModelsCommand}" 
                                    Style="{StaticResource SmallButton}" Margin="4,0,0,0" Width="30" FontSize="11"
                                    ToolTip="{loc:Loc config.manage_models}"/>
                        </Grid>

                        <Border Background="#2D2D30" CornerRadius="4" Padding="8" Margin="0,2,0,4"
                                Visibility="{Binding HasSelectedBenchmark, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="{loc:Loc config.last_benchmark}" FontSize="10" FontWeight="SemiBold" 
                                            Foreground="#4EC9B0" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding SelectedBenchmarkDisplay}" 
                                           Foreground="{Binding SelectedBenchmarkColor, Converter={StaticResource StringToBrushConverter}}" 
                                           FontSize="10"
                                           FontFamily="Cascadia Code, Consolas"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Height="1" Background="#3F3F46" Margin="0,4,0,4" Opacity="0.6"/>

                        <TextBlock Style="{StaticResource SubSectionHeader}">
                            <Run Text="🌐"/>
                            <Run Text="{loc:Loc server.title}"/>
                        </TextBlock>

                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <Label Content="Host" Margin="0,0,0,1"/>
                                <TextBox Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <Label Content="Port" Margin="0,0,0,1"/>
                                <TextBox Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <Button Grid.Column="4" Content="🔗" Command="{Binding OpenServerCommand}"
                                    Style="{StaticResource SmallButton}" Width="30" VerticalAlignment="Bottom"
                                    ToolTip="{loc:Loc server.open_browser}"/>
                        </Grid>

                        <Border Height="1" Background="#3F3F46" Margin="0,4,0,4" Opacity="0.6"/>

                        <TextBlock Style="{StaticResource SubSectionHeader}">
                            <Run Text="⚡"/>
                            <Run Text="{loc:Loc benchmark.title}"/>
                        </TextBlock>

                        <UniformGrid Columns="2" Margin="0,0,0,4">
                            <Grid Margin="0,0,4,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Label Grid.Column="0" Content="NGL" VerticalContentAlignment="Center" Padding="0" FontSize="10"/>
                                <TextBox Grid.Column="1" Text="{Binding BenchmarkNgl, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" FontSize="10" Padding="4,2"/>
                            </Grid>
                            <Grid Margin="0,0,4,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Label Grid.Column="0" Content="Cache K" VerticalContentAlignment="Center" Padding="0" FontSize="10"/>
                                <TextBox Grid.Column="1" Text="{Binding BenchmarkCacheTypeK, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" FontSize="10" Padding="4,2"/>
                            </Grid>
                            <Grid Margin="0,0,4,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Label Grid.Column="0" Content="Cache V" VerticalContentAlignment="Center" Padding="0" FontSize="10"/>
                                <TextBox Grid.Column="1" Text="{Binding BenchmarkCacheTypeV, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" FontSize="10" Padding="4,2"/>
                            </Grid>
                            <Grid Margin="0,0,4,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Label Grid.Column="0" Content="Prompt" VerticalContentAlignment="Center" Padding="0" FontSize="10"/>
                                <TextBox Grid.Column="1" Text="{Binding BenchmarkPromptTokens, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" FontSize="10" Padding="4,2"/>
                            </Grid>
                            <Grid Margin="0,0,4,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Label Grid.Column="0" Content="Generation" VerticalContentAlignment="Center" Padding="0" FontSize="10"/>
                                <TextBox Grid.Column="1" Text="{Binding BenchmarkGenerationTokens, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" FontSize="10" Padding="4,2"/>
                            </Grid>
                            <Grid Margin="0,0,4,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Label Grid.Column="0" Content="Repetitions" VerticalContentAlignment="Center" Padding="0" FontSize="10"/>
                                <TextBox Grid.Column="1" Text="{Binding BenchmarkRepetitions, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" FontSize="10" Padding="4,2"/>
                            </Grid>
                        </UniformGrid>

                        <Button Content="Benchmark All" 
                                Command="{Binding BenchmarkAllCommand}"
                                Style="{StaticResource SmallButton}" 
                                Margin="0,0,0,3"
                                HorizontalAlignment="Stretch"/>

                        <Button Content="Benchmark Missing" 
                                Command="{Binding BenchmarkMissingCommand}"
                                Style="{StaticResource SmallButton}" 
                                Margin="0,0,0,4"
                                HorizontalAlignment="Stretch"/>

                        <StackPanel Visibility="{Binding IsBenchmarking, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="{Binding BenchmarkStatus}" 
                                       Foreground="#D4D4D4" 
                                       FontSize="10"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,3"/>
                            <ProgressBar Value="{Binding BenchmarkProgress}" 
                                          Maximum="{Binding BenchmarkTotal}" 
                                          Height="6"
                                          Background="#2D2D30"
                                          Foreground="#007ACC"
                                          BorderThickness="0"/>
                            <TextBlock Margin="0,6,0,0"
                                       HorizontalAlignment="Center">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0} / {1}">
                                        <Binding Path="BenchmarkProgress"/>
                                        <Binding Path="BenchmarkTotal"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                                <TextBlock.Foreground>#B0B0B0</TextBlock.Foreground>
                                <TextBlock.FontSize>11</TextBlock.FontSize>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeader}">
                                <Run Text="🔧"/>
                                <Run Text="{loc:Loc params.title}"/>
                            </TextBlock>

                            <ItemsControl ItemsSource="{Binding Parameters}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="2"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,4,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Label Grid.Column="0" Content="{Binding DisplayName}" 
                                                   VerticalContentAlignment="Center" Padding="0" FontSize="10"/>
                                            <TextBox Grid.Column="1" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" 
                                                     VerticalContentAlignment="Center" FontSize="10" Padding="4,2"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="1" Margin="0,4,0,0">
                        <Border Height="1" Background="#3F3F46" Margin="0,0,0,4" Opacity="0.6"/>

                        <TextBlock Style="{StaticResource SubSectionHeader}">
                            <Run Text="💾"/>
                            <Run Text="{loc:Loc profiles.title}"/>
                        </TextBlock>

                        <ComboBox ItemsSource="{Binding ProfileNames}" 
                                  SelectedItem="{Binding SelectedProfile}" 
                                  Margin="0,0,0,4"/>

                        <WrapPanel>
                            <Button Content="{loc:Loc profiles.save}" Command="{Binding SaveProfileCommand}" 
                                    Style="{StaticResource SmallButton}" Margin="0,0,4,0"/>
                            <Button Content="{loc:Loc profiles.load}" Command="{Binding LoadProfileCommand}" 
                                    Style="{StaticResource SmallButton}" Margin="0,0,4,0"/>
                            <Button Content="{loc:Loc profiles.import}" Command="{Binding ImportCommandCommand}" 
                                    Style="{StaticResource SmallButton}"/>
                        </WrapPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,4">
                        <TextBlock Style="{StaticResource SectionHeader}" Margin="0" VerticalAlignment="Center">
                            <Run Text="📋"/>
                            <Run Text="{loc:Loc console.title}"/>
                        </TextBlock>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                            <TextBlock Text="{Binding LogCountDisplay}" 
                                       Foreground="#6D6D6D" FontSize="11" VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <Button Content="{loc:Loc console.copy}" Command="{Binding CopyLogsCommand}" 
                                    Style="{StaticResource SmallButton}" Margin="0,0,6,0"
                                    ToolTip="{loc:Loc console.copy_tooltip}"/>
                            <Button Content="{loc:Loc console.clear}" Command="{Binding ClearLogsCommand}" 
                                    Style="{StaticResource SmallButton}"
                                    ToolTip="{loc:Loc console.clear_tooltip}"/>
                        </StackPanel>
                    </DockPanel>

                    <Border Grid.Row="1" Background="#1A1A1A" CornerRadius="6" Padding="8">
                        <ListBox ItemsSource="{Binding Logs}" 
                                 Background="Transparent"
                                 BorderThickness="0"
                                 x:Name="LogsListBox"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" 
                                               FontFamily="Cascadia Code, Consolas, Courier New" 
                                               FontSize="11" 
                                               Foreground="#D4D4D4"
                                               TextWrapping="NoWrap"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="4,2"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#D4D4D4"/>
                                    <Setter Property="IsHitTestVisible" Value="False"/>
                                    <Style.Triggers>
                                        <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                            <Setter Property="Background" Value="#1E1E1E"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.AlternationCount>2</ListBox.AlternationCount>
                        </ListBox>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#252526" CornerRadius="8" Padding="8" Margin="12,0,12,6">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.25" Color="#000000"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="{loc:Loc action.start}" Command="{Binding StartCommand}" 
                        Style="{StaticResource StartButton}" Width="120" Margin="0,0,8,0"
                        ToolTip="{loc:Loc action.start_tooltip}"/>
                <Button Content="{loc:Loc action.stop}" Command="{Binding StopCommand}" 
                        Style="{StaticResource StopButton}" Width="120" Margin="0,0,8,0"
                        ToolTip="{loc:Loc action.stop_tooltip}"/>
                <Button Content="{loc:Loc action.restart}" Command="{Binding RestartCommand}" 
                        Style="{StaticResource RestartButton}" Width="120"
                        ToolTip="{loc:Loc action.restart_tooltip}"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Background="#1E1E1E" BorderBrush="#3F3F46" BorderThickness="0,1,0,0" Padding="12,6">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Ellipse Width="8" Height="8" Margin="0,0,8,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#6D6D6D"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                        <Setter Property="Fill" Value="#4EC9B0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding StatusText}" FontSize="11" Foreground="#B0B0B0" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding StatusBarVersion}" 
                               FontSize="11" Foreground="#6D6D6D" VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <TextBlock Text="{Binding StatusBarModel}" 
                               FontSize="11" Foreground="#6D6D6D" VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
